{
  "name": "excel-ai-assistant",
  "version": "0.1.81",
  "description": "Office AI 桌面助手 - 通过 AI 帮你处理表格、文档和演示文稿",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/check-renderer-bundle-budget.cjs",
    "preview": "vite preview",
    "electron:build": "npm run office:publish && node scripts/clean-build-output.cjs && npm run build && node scripts/electron-builder-with-mirror.cjs --win nsis --x64 --publish never",
    "office:build": "node scripts/run-dotnet.cjs build dotnet/Wengge.OfficeAutomation.sln --configuration Release",
    "office:test": "node scripts/run-dotnet.cjs test dotnet/Wengge.OfficeAutomation.sln --configuration Release",
    "office:audit": "node scripts/check-nuget-vulnerabilities.cjs",
    "office:publish": "node scripts/run-dotnet.cjs publish dotnet/Wengge.OfficeWorker/Wengge.OfficeWorker.csproj --configuration Release --runtime win-x64 --self-contained true --output dotnet/publish/win-x64",
    "patch:build": "node scripts/create-hot-patch.cjs",
    "release:verify": "vite-node scripts/verify-release-manifest.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "test:office-smoke": "npm run office:publish && vite-node scripts/smoke-office-advanced.ts",
    "test:word-smoke": "npm run office:publish && vite-node scripts/smoke-word-advanced.ts",
    "test:word-lifecycle": "npm run office:publish && vite-node scripts/smoke-word-lifecycle.ts",
    "test:excel-lifecycle": "npm run office:publish && vite-node scripts/smoke-excel-lifecycle.ts",
    "test:presentation-smoke": "npm run office:publish && vite-node scripts/smoke-presentation-advanced.ts",
    "test:office-reliability": "npm run office:publish && vite-node scripts/smoke-office-reliability.ts",
    "test:wps-routing": "npm run office:publish && vite-node scripts/smoke-wps-routing.ts"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.excel-ai.assistant",
    "productName": "文格 AI 助手",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dotnet/publish/win-x64",
        "to": "office-worker",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "artifactName": "Wengge-AI-Assistant-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "文格 AI 助手",
      "installerSidebar": "build/installer-sidebar.bmp",
      "installerHeader": "build/installer-header.bmp",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://plugin.shelelove.top/releases/windows"
      }
    ]
  }
}
