{
  "name": "excel-ai-assistant",
  "version": "0.1.47",
  "description": "Office AI 桌面助手 - 通过 AI 帮你处理表格、文档和演示文稿",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "vite build && node scripts/electron-builder-with-mirror.cjs --win nsis --x64 --publish never",
    "native:rebuild": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.2",
    "vite": "^8.1.2",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.excel-ai.assistant",
    "productName": "Office AI 助手",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Office AI 助手"
    },
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
