# Listen (production should bind loopback only)
AI_GATEWAY_HOST=127.0.0.1
AI_GATEWAY_PORT=8787

# JSON object: upstreamId -> { baseUrl, auth }
# baseUrl must be absolute https (http only for local test with AI_GATEWAY_ALLOW_LOCAL_UPSTREAMS=1)
# auth: { "type": "bearer"|"x-api-key", "env": "ENV_VAR_NAME" }
AI_GATEWAY_UPSTREAMS_JSON={"openai":{"baseUrl":"https://api.openai.com/v1","auth":{"type":"bearer","env":"OPENAI_API_KEY"}},"anthropic":{"baseUrl":"https://api.anthropic.com/v1","auth":{"type":"x-api-key","env":"ANTHROPIC_API_KEY"}}}

# Secrets referenced by auth.env (never commit real values)
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# Timeouts (ms)
AI_GATEWAY_CONNECT_TIMEOUT_MS=10000
AI_GATEWAY_TOTAL_TIMEOUT_MS=120000

# Limits (fail-closed)
AI_GATEWAY_MAX_CONCURRENT=32
AI_GATEWAY_RATE_LIMIT_MAX=60
AI_GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# Development / tests only: allow http://127.0.0.1 upstreams. Never enable in production.
AI_GATEWAY_ALLOW_LOCAL_UPSTREAMS=0
